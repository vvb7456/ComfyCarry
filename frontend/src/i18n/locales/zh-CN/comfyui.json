  "params": {
    "fields": {
      "vram": {
        "label": "VRAM 管理",
        "help": "控制模型显存分配策略。默认自动检测，High VRAM 适合大显存 GPU 不卸载模型，Low VRAM 适合小显存拆分推理。",
        "options": {
          "default": "默认 (自动)",
          "gpu-only": "GPU Only (全部保留在 GPU)",
          "highvram": "High VRAM (模型不卸载)",
          "normalvram": "Normal VRAM (强制正常模式)",
          "lowvram": "Low VRAM (拆分 UNet)",
          "novram": "No VRAM (极限低显存)"
        }
      },
      "attention": {
        "label": "Attention 方案",
        "help": "PyTorch SDPA 为推荐方案，会自动调用更优内核。FlashAttention 和 SageAttention 可在 Setup Wizard 中安装。",
        "options": {
          "default": "默认 (自动选择)",
          "pytorch-cross": "PyTorch SDPA (推荐)",
          "split-cross": "Split Cross Attention (省显存)",
          "quad-cross": "Sub-Quadratic",
          "flash": "FlashAttention",
          "sage": "SageAttention"
        }
      },
      "disable_xformers": {
        "label": "xFormers",
        "help": "新版 PyTorch 下通常更建议使用 PyTorch SDPA，如无特殊需求可保持禁用 xFormers。",
        "options": {
          "default": "默认",
          "disabled": "禁用"
        }
      },
      "unet_precision": {
        "label": "UNet 精度",
        "help": "控制 UNet 推理精度。FP8 可明显降低显存占用，BF16 适合 Ampere 及更新架构。",
        "options": {
          "default": "默认 (自动)",
          "fp32": "FP32",
          "fp16": "FP16",
          "bf16": "BF16",
          "fp8_e4m3fn": "FP8 (e4m3fn)",
          "fp8_e5m2": "FP8 (e5m2)"
        }
      },
      "vae_precision": {
        "label": "VAE 精度",
        "help": "控制 VAE 解码精度。FP32 最稳，FP16/BF16 更快；如果出现黑图，可尝试改回 FP32。",
        "options": {
          "default": "默认 (自动)",
          "fp32": "FP32",
          "fp16": "FP16",
          "bf16": "BF16",
          "cpu": "CPU (在 CPU 上运行)"
        }
      },
      "text_enc_precision": {
        "label": "Text Encoder 精度",
        "help": "控制文本编码器精度。一般保持默认即可，FP8 可进一步节省显存。",
        "options": {
          "default": "默认 (自动)",
          "fp32": "FP32",
          "fp16": "FP16",
          "bf16": "BF16",
          "fp8_e4m3fn": "FP8 (e4m3fn)",
          "fp8_e5m2": "FP8 (e5m2)"
        }
      },
      "fast": {
        "label": "实验性优化",
        "help": "启用 ComfyUI 的实验性加速，可能提升速度，但极少数工作流存在兼容性风险。",
        "options": {
          "default": "关闭",
          "enabled": "启用"
        }
      },
      "preview_method": {
        "label": "预览方式",
        "help": "控制生成过程中的实时预览。TAESD 观感更好但略慢，Latent2RGB 速度更快但会更模糊。",
        "options": {
          "auto": "自动",
          "none": "无",
          "latent2rgb": "Latent2RGB",
          "taesd": "TAESD"
        }
      },
      "cache": {
        "label": "缓存策略",
        "help": "控制节点输出缓存方式。只有选择 LRU 时，下方的 LRU 缓存大小才会生效；经典模式更激进、更快，但占用更多内存。",
        "options": {
          "default": "默认",
          "classic": "经典 (Aggressive)",
          "lru": "LRU",
          "none": "禁用"
        }
      },
      "cache_lru_size": {
        "label": "LRU 缓存大小",
        "help": "设置最多保留多少个节点结果用于复用。值越大，重复执行时越容易命中缓存，但会占用更多内存。仅在缓存策略为 LRU 时生效。",
        "options": {
          "16": "16",
          "32": "32",
          "64": "64",
          "128": "128",
          "256": "256"
        }
      }
    }
  },
